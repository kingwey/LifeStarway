# ============================================
# LifeStarway 后端环境变量模板
# 复制为 .env 后填写真实值
# ============================================

# 应用配置
APP_NAME=人生星途
APP_ENV=development
DEBUG=true

# 数据库（开发环境使用SQLite，生产使用PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./lifestarway.db
# DATABASE_URL=postgresql+asyncpg://lifestarway:password@localhost:5432/lifestarway

# Redis
REDIS_URL=redis://localhost:6379/0

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5175,http://localhost:8080

# LLM 配置
LLM_PROVIDER=dashscope
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=
LLM_MODEL=

# Tavily 搜索
TAVILY_API_KEY=your-tavily-key-here

# GitHub API Token（公开信息采集）
GITHUB_TOKEN=your-github-token-here
