SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 开发环境使用 SQLite，生产环境切换为 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./lifestarway.db
# DATABASE_URL=postgresql+asyncpg://lifestarway:your_password@localhost:5432/lifestarway

# Redis 缓存
REDIS_URL=redis://localhost:6379/0

# ---- AI 服务配置 ----
# 默认使用的 LLM 提供商: dashscope / doubao / gemini
LLM_PROVIDER=dashscope

# 阿里云 DashScope (通义千问) - OpenAI 兼容
DASHSCOPE_API_KEY=

# 豆包 (字节跳动) - OpenAI 兼容
DOUBAO_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Tavily 搜索 API
TAVILY_API_KEY=

# 以下三项由 LLM_PROVIDER 自动推导，也可手动覆盖
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
